# LoreAI v2 — Environment Variables
# Copy to .env and fill in values

# AI APIs
ANTHROPIC_API_KEY=  # optional — only needed if using API directly; Claude CLI uses Max Plan
MOONSHOT_API_KEY=

# Twitter (twitterapi.io)
TWITTER_API_KEY=
TWITTER_API_SECRET=

# GitHub
GITHUB_TOKEN=

# Reddit OAuth
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Brave Search (free tier, 2000 queries/month)
BRAVE_SEARCH_API_KEY=

# Buttondown (newsletter delivery)
BUTTONDOWN_API_KEY=

# Database (VPS only, defaults to ./loreai.db)
# DB_PATH=/home/ubuntu/loreai-v2/loreai.db
